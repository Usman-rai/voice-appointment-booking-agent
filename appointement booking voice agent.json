    {
      "parameters": {
        "jsCode": "// Get free/busy result from previous node\nconst result = $input.first().json;\n\n// Get the callId straight from the webhook (stable reference)\nconst toolCall = $('Webhook').first().json.body.message.toolCalls[0];\nconst callId = toolCall.id;\n\n// Build the message VAPI will speak\nconst message = result.isFree\n  ? \"That time is available. Would you like me to book it?\"\n  : \"Sorry, that time is taken. Would another time work?\";\n\n// VAPI's required response format\nreturn [{\n  json: {\n    results: [\n      {\n        toolCallId: callId,\n        result: message\n      }\n    ]\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        -96
      ],
      "id": "5146908a-0204-438e-b649-9c0bc14941cd",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst toolCall = body.message.toolCalls[0];\nconst args = toolCall.function[\"arguments\"];\nconst parsed = typeof args === \"string\" ? JSON.parse(args) : args;\n\n// Safety net: if the model still sends a past year, fall back to tomorrow\nconst nowStr = body.message.artifact?.variables?.now;\nconst today = nowStr ? new Date(nowStr) : new Date();\nlet dateStr = parsed.date;\nconst md = new Date(parsed.date);\nif (isNaN(md.getTime()) || md.getFullYear() < today.getFullYear()) {\n  const t = new Date(today);\n  t.setDate(today.getDate() + 1);\n  dateStr = `${t.getFullYear()}-${String(t.getMonth()+1).padStart(2,\"0\")}-${String(t.getDate()).padStart(2,\"0\")}`;\n}\n\nreturn [{\n  json: {\n    requestedDate: dateStr,\n    requestedTime: parsed.time,\n    dayStart: `${dateStr}T00:00:00`,\n    dayEnd: `${dateStr}T23:59:59`,\n    callId: toolCall.id\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        -96
      ],
      "id": "903176fe-dd88-410d-ab16-cdbb84673648",
