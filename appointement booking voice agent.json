    {
      "parameters": {
        "jsCode": "const events = $input.all();\nconst realEvents = events.filter(e => e.json && e.json.start && e.json.start.dateTime);\nconst isFree = realEvents.length === 0;\n\nreturn [{\n  json: {\n    isFree: isFree,\n    status: isFree ? \"free\" : \"busy\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        656,
        -96
      ],
      "id": "3c0c9dee-687d-4df5-87e3-15f5288fde98",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// Reads only the incoming item — no node-name references\nconst body = $input.first().json.body;\nconst toolCall = body.message.toolCalls[0];\nconst args = toolCall.function[\"arguments\"];\nconst parsed = typeof args === \"string\" ? JSON.parse(args) : args;\n\n// VAPI's real current date lives in the payload\nconst nowStr = body.message.artifact?.variables?.now;\nconst today = nowStr ? new Date(nowStr) : new Date();\n\n// Model often sends a past/wrong date → fall back to tomorrow\nlet finalDate = parsed.date;\nconst modelDate = new Date(parsed.date);\nif (isNaN(modelDate.getTime()) || modelDate.getFullYear() < today.getFullYear()) {\n  const t = new Date(today);\n  t.setDate(today.getDate() + 1);\n  const y = t.getFullYear();\n  const m = String(t.getMonth() + 1).padStart(2, \"0\");\n  const d = String(t.getDate()).padStart(2, \"0\");\n  finalDate = `${y}-${m}-${d}`;\n}\n\nconst serviceMap = {\n  \"cleaning\": \"Cleaning\", \"filling\": \"Filling\", \"whitening\": \"Whitening\",\n  \"dentures\": \"Dentures\", \"denture\": \"Dentures\", \"checkup\": \"Checkup\",\n  \"emergency\": \"Emergency\", \"emergency visit\": \"Emergency\", \"consultation\": \"Consultation\"\n};\nconst rawService = (parsed.service || \"\").toLowerCase().trim();\nconst service = serviceMap[rawService] || \"Consultation\";\n\nreturn [{\n  json: {\n    name: parsed.name || \"Patient\",\n    phone: parsed.phone || \"\",\n    service: service,\n    requestedDate: finalDate,\n    requestedTime: parsed.time || \"10:00 AM\",\n    callId: toolCall.id\n  }\n}];"
      },
